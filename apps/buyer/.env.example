# ── Public vars (inlined at build time by Next.js) ──────────────────────────

# Base URL for the app — used in sitemap.ts
NEXT_PUBLIC_BASE_URL=https://app.knowledgeos.io

# Display name used in <title> and meta tags
NEXT_PUBLIC_APP_NAME=KnowledgeOS

# Stripe publishable key — optional, billing UI degrades gracefully without it
NEXT_PUBLIC_STRIPE_KEY=pk_test_...

# WebSocket gateway endpoint (ws-gateway on port 8011)
# NOTE: currently hardcoded in hooks/use-websocket.ts as ws://localhost:8011/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8011/ws

# ── Server-only vars (not inlined, available to middleware + API routes) ─────

# JWT secret for Edge middleware token verification
JWT_SECRET=change-me-in-production

# ── API proxy ────────────────────────────────────────────────────────────────
# All /api/* requests are rewritten by Next.js to the backend services
# (configured in next.config.ts — no NEXT_PUBLIC_API_URL needed in client code)
#
#   /api/identity/*  → http://localhost:8001
#   /api/course/*    → http://localhost:8002
#   /api/enrollment/* → http://localhost:8003
#   /api/payment/*   → http://localhost:8004
#   /api/notification/* → http://localhost:8005
#   /api/ai/*        → http://localhost:8006
#   /api/learning/*  → http://localhost:8007
#   /api/rag/*       → http://localhost:8008

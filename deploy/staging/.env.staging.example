# Staging environment configuration
# Copy to .env.staging and fill in real values
# Usage: docker compose -f docker-compose.staging.yml --env-file deploy/staging/.env.staging up -d

# --- Container registry ---
GHCR_OWNER=your-github-org
IMAGE_TAG=latest

# --- Database passwords ---
IDENTITY_DB_PASSWORD=
COURSE_DB_PASSWORD=
ENROLLMENT_DB_PASSWORD=
PAYMENT_DB_PASSWORD=
NOTIFICATION_DB_PASSWORD=
LEARNING_DB_PASSWORD=

# --- Shared secrets ---
JWT_SECRET=
ALLOWED_ORIGINS=https://staging.example.com

# --- AI service ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

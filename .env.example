# KnowledgeOS Demo Environment
# Copy to .env before starting: cp .env.example .env
# Values marked CHANGE_IN_PROD must be replaced before any production deployment.

# ============================================
# Required — set these for any environment
# ============================================

# JWT signing secret shared by api-gateway and ws-gateway (Rust services).
# Python services also read this in docker-compose.prod.yml.
# CHANGE_IN_PROD: generate with `openssl rand -hex 32`
JWT_SECRET=demo-jwt-secret-change-in-production

# ============================================
# Optional — empty = mock / degraded mode (safe for demo)
# ============================================

# Gemini LLM key (ai service + embedding-orchestrator).
# When empty, ai service falls back to MockLLMProvider automatically.
GEMINI_API_KEY=

# Gemini model to use (ai service).
GEMINI_MODEL=gemini-2.0-flash-lite

# Gemini embedding endpoint (embedding-orchestrator).
GEMINI_EMBEDDING_URL=https://generativelanguage.googleapis.com/v1beta/models

# Stripe secret key (payment service).
# When empty, Stripe calls fail but all other payment endpoints still work.
STRIPE_SECRET_KEY=

# MCP server auth token (profile: mcp, optional).
MCP_AUTH_TOKEN=

# ============================================
# Infrastructure — defaults work with docker-compose
# ============================================

# Redis — used by all Python services for caching and sessions.
REDIS_URL=redis://redis:6379

# CORS allowed origins for api-gateway.
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ============================================
# Database URLs — set by docker-compose automatically.
# Override here only when connecting to external DBs.
# ============================================

# IDENTITY_DATABASE_URL=postgresql://identity:identity@identity-db:5432/identity
# COURSE_DATABASE_URL=postgresql://course:course@course-db:5432/course
# ENROLLMENT_DATABASE_URL=postgresql://enrollment:enrollment@enrollment-db:5432/enrollment
# PAYMENT_DATABASE_URL=postgresql://payment:payment@payment-db:5432/payment
# NOTIFICATION_DATABASE_URL=postgresql://notification:notification@notification-db:5432/notification
# LEARNING_DATABASE_URL=postgresql://learning:learning@learning-db:5432/learning
# RAG_DATABASE_URL=postgresql://rag:rag@rag-db:5432/rag

# ============================================
# Frontend (Next.js buyer app)
# NEXT_PUBLIC_* vars are inlined at build time — restart required after changes.
# ============================================

# Base URL for REST API calls from the browser → api-gateway.
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket endpoint → ws-gateway.
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# App display name used in <title> and meta tags.
NEXT_PUBLIC_APP_NAME=KnowledgeOS

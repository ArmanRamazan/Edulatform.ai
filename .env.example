# KnowledgeOS dev environment variables
# Copy to .env and fill in real values where needed.
# Services start without these — they only affect optional integrations.

# ── AI / Embeddings ────────────────────────────────────────────────────────────
# Required for ai service (Gemini LLM) and embedding-orchestrator.
# Without these, ai service uses MockLLMProvider and embedding-orchestrator
# returns errors on actual embedding calls (but still starts).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# URL of the Gemini embedding endpoint (embedding-orchestrator uses this).
# Default is set in docker-compose.dev.yml if not provided.
GEMINI_EMBEDDING_URL=https://generativelanguage.googleapis.com/v1beta/models

# ── Payments ───────────────────────────────────────────────────────────────────
# Required for payment service Stripe integration.
# Without these, Stripe calls fail but service starts and non-Stripe endpoints work.
STRIPE_SECRET_KEY=

# ── Auth ───────────────────────────────────────────────────────────────────────
# JWT secret shared by api-gateway and ws-gateway (Rust services).
# Python services use JWT_SECRET (hardcoded to dev-secret-key in docker-compose.dev.yml).
JWT_SECRET=dev-jwt-secret-key-at-least-32-chars!!

# ── MCP ────────────────────────────────────────────────────────────────────────
# Auth token for MCP server (profile: mcp). Optional.
MCP_AUTH_TOKEN=
